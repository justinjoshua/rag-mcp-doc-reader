# Copy to .env and fill in.  The app loads this automatically.

# --- Answer backend --------------------------------------------------------
# How retrieved passages become an answer:
#   gemini     -> Google Gemini API (needs GEMINI_API_KEY below)
#   extractive -> no LLM, no key: returns the ranked passages (works offline)
#   ollama     -> local LLM via Ollama (free, offline, no key)
ANSWER_BACKEND=gemini

# --- Gemini (used when ANSWER_BACKEND=gemini) ------------------------------
# Get a key at https://aistudio.google.com/apikey  (format: AIza...)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OCR for scanned/image PDFs (renders pages -> Gemini transcribes). Needs the key.
OCR=true
OCR_MAX_PAGES=60

# --- Ollama (used when ANSWER_BACKEND=ollama) ------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Embeddings ------------------------------------------------------------
# "local"  -> sentence-transformers, runs on your machine, no key, no cost.
# "voyage" -> Voyage AI hosted embeddings (higher quality). Needs VOYAGE_API_KEY.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
# VOYAGE_API_KEY=

# --- Storage / chunking / retrieval ----------------------------------------
DB_PATH=./chroma_db
DOCS_DIR=./docs
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=6

# Retrieval quality
RETRIEVAL_MODE=hybrid                 # hybrid (vector+keyword) or vector
RERANK=true                           # cross-encoder re-ranking (better answers)
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
